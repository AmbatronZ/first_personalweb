<style>
  .sidebar {
  width: 250px;
  background: linear-gradient(to bottom right, rgb(47, 47, 47), rgb(0, 0, 0));
  font-family: 'Tektur', sans-serif;
  font-size: 20px;
}
.navbar {
  background: linear-gradient(45deg, rgb(135, 19, 19), rgb(255, 0, 0));
  height: 120px;
  font-family: 'Tektur',sans-serif;
  font-size: 20px;
}
.navbar-brand {
  font-weight: bold;
  color: #ffffff;
}
.navbar-nav .nav-link {
  color: #ffffff;
  margin-right: 10px;
  transition: color 0.3s ease;
}
.navbar-nav .nav-link:hover {
  color: #ffdd57;
}
.dropdown-menu {
  background-color: #4e54c8;
  border: none;
}
.dropdown-menu .dropdown-item {
  color: #ffffff;
}
.dropdown-menu .dropdown-item:hover {
  background-color: #ffdd57;
  color: #000000;
}
.btn-custom {
  background-color: #ffdd57;
  color: #000000;
  border-radius: 20px;
  transition: background-color 0.3s ease;
}
.btn-custom:hover {
  background-color: #ffe884;
  color: #000000;
}
.hero {
background-size: cover;
background-position: center;
height: 500px;
color: white;
text-align: center;
padding: 100px 20px;
font-family: 'Tektur';
}

.hero h1 {
font-size: 48px;
font-weight: bold;
}

.hero span {
color: #ff0000;
}

.carousel-text-overlay {
position: absolute;
top: 50%;
left: 50%;
transform: translate(-50%, -50%);
