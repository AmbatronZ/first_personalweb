text-align: center;
z-index: 10;
font-family: 'Tektur';
padding: 20px;
width: 100%;
}

.carousel-text-overlay h1 {
font-size: 48px;
font-weight: bold;
}

.carousel-text-overlay span {
color: #ff0000;
